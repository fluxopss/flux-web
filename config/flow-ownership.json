  "pre_action_checks": [
    "Read contact tags before any GHL write",
    "If tag ghl_wf_active exists, skip workflow enrollment",
    "If tag comet_intake exists, skip lead creation — only validate/update",
    "If tag cursor_stage_set matches target stage, skip stage advance",
    "If Stripe webhook handles close, skip ghl-stripe-close stage advance",
