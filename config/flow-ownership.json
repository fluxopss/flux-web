    "cursor_stage_set": "Cursor advanced stage — check before re-advancing",
    "stripe_payment_linked": "Stripe payment URL/metadata attached",
    "fulfillment_complete": "All required fields present for current stage",
    "enrichment_pending": "Missing phone/email — queued for gap fill",
    "pitch_ready": "Qualified and ready for GHL proposal workflow",
    "deal_hunter_2026-06-26": "Batch tag — do not duplicate pitch"
